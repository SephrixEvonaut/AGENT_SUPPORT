{
  "name": "swtor-macro-agent",
  "version": "1.0.0",
  "description": "Per-key gesture detection and macro sequencing for SWTOR",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "preflight": "node scripts/preflight.mjs",
    "start": "node dist/index.js",
    "prestart": "npm run preflight",
    "start:teensy": "node dist/index.js --backend=teensy --system=omega --cooldowns=no",
    "prestart:teensy": "npm run preflight",
    "start:software": "node dist/index.js --backend=robotjs --system=omega --cooldowns=no",
    "prestart:software": "npm run preflight",
    "tank": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=T",
    "pretank": "npm run preflight",
    "rage": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=R",
    "prerage": "npm run preflight",
    "sorc": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=S",
    "presorc": "npm run preflight",
    "madness": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=M",
    "premadness": "npm run preflight",
    "engi": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=E",
    "preengi": "npm run preflight",
    "cmedic": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=C",
    "precmedic": "npm run preflight",
    "arsenal": "node dist/index.js --backend=teensy --system=omega --cooldowns=no --char=A",
    "prearsenal": "npm run preflight",
    "start:dev": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "manifest:validate": "tsx scripts/manifestSync.ts --validate",
    "manifest:export": "tsx scripts/manifestSync.ts --export",
    "manifest:import": "tsx scripts/manifestSync.ts --import",
    "teensy:test": "tsx scripts/teensyTest.ts",
    "teensy:test:full": "tsx scripts/teensyTest.ts --full",
    "teensy:test:latency": "tsx scripts/teensyTest.ts --latency",
    "calibrate": "node dist/calibrationCli.js",
    "calibrate:hot": "node dist/calibrationCli.js --hot-reload",
    "calibrate:quick": "node dist/calibrationCli.js --quick"
  },
  "dependencies": {
    "node-global-key-listener": "^0.3.0",
    "robotjs": "^0.6.0",
    "say": "^0.16.0",
    "serialport": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
